L=0135, P=005A, C=7017 : 					CALL  RGB1W_DLY_0H		;HIGH 294n IF 0
L=0136, P=005B, C=5F01 : 					BTSS  SFR_INDIR_PORT2,7	;BIT SFR_INDIR_PORT2.7
L=0137, P=005C, C=400B : 					BC    SFR_PORT_IO,SB_PORT_OUT0	;BIT0
L=0138, P=005D, C=7010 : 					CALL  RGB1W_DLY_HALF	;APPEND 581n FOR HIGH/LOW
L=0139, P=005E, C=400B : 					BC    SFR_PORT_IO,SB_PORT_OUT0	;FALL EDGE
L=0140, P=005F, C=7016 : 					CALL  RGB1W_DLY_1L		;LOW 294n IF 1
L=0141, ......, D=0000 : 
L=0142, P=0060, C=480B : 					BS    SFR_PORT_IO,SB_PORT_OUT0	;RISE EDGE
L=0143, P=0061, C=7017 : 					CALL  RGB1W_DLY_0H		;HIGH 294n IF 0
L=0144, P=0062, C=5E01 : 					BTSS  SFR_INDIR_PORT2,6	;BIT SFR_INDIR_PORT2.6
L=0145, P=0063, C=400B : 					BC    SFR_PORT_IO,SB_PORT_OUT0	;BIT0
L=0146, P=0064, C=7010 : 					CALL  RGB1W_DLY_HALF	;APPEND 581n FOR HIGH/LOW
L=0147, P=0065, C=400B : 					BC    SFR_PORT_IO,SB_PORT_OUT0	;FALL EDGE
L=0148, P=0066, C=7016 : 					CALL  RGB1W_DLY_1L		;LOW 294n IF 1
L=0149, ......, D=0000 : 
