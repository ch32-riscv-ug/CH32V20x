L=0068, ......, D=0000 : ;
L=0069, ......, D=0000 : ; SFR_CTRL_WR: COMMAND
L=0070, ......, D=0000 : ;     01H-20H: RGB WITH SHORT DATA IN SFR, LOW 7 BIT IS TOTAL BYTE
L=0071, ......, D=0000 : ;         70H: RGB WITH LONG DATA IN CODE RAM
L=0072, ......, D=0000 : ;         41H: DS1W START CONVERT
L=0073, ......, D=0000 : ;         42H: DS1W GET TEMPERATURE
L=0074, ......, D=0000 : ;         43H: DS1W START CONVERT THEN GET TEMPERATURE
L=0075, ......, D=0000 : ;
L=0076, P=0025, C=5E1C : WAIT_COMMAND:		BTSS  SFR_SYS_CFG,SB_DATA_SW_MR	;WAIT MASTER ACK
L=0077, P=0026, C=471C : 					BC    SFR_SYS_CFG,SB_INT_REQ	;CANCEL INTERRUPT IF ACK
L=0078, P=0027, C=5D1C : 					BTSS  SFR_SYS_CFG,SB_DATA_MW_SR	;NEW COMMAND
L=0079, P=0028, C=6025 : 					JMP   WAIT_COMMAND		;WAIT COMMAND
L=0080, P=0029, C=471C : 					BC    SFR_SYS_CFG,SB_INT_REQ	;CANCEL INTERRUPT
L=0081, P=002A, C=021E : 					MOV   SFR_CTRL_WR,A		;COMMAND CODE
L=0082, P=002B, C=1009 : 					MOVA  SFR_INDIR_ADDR2
L=0083, P=002C, C=C13D : 					CMPZ  0X41,DS1W_CONVERT
L=0084, P=002D, C=C24A : 					CMPZ  0X42,DS1W_GET_DATA
L=0085, P=002E, C=C340 : 					CMPZ  0X43,DS1W_CONV_GET
L=0086, P=002F, C=F0EE : 					CMPZ  0X70,RGB1W_LONG
L=0087, P=0030, C=803B : 					CMPZ  0X00,CMD_UNKNOWN	;UNKNOWN COMMAND
L=0088, P=0031, C=2F20 : 					CMPL  0X20
L=0089, P=0032, C=384D : 					JNC   RGB1W_SHORT		;SHORT DATA IN SFR IF <=0X20
L=0090, P=0033, C=2F60 : 					CMPL  0X60
L=0091, P=0034, C=389F : 					JNC   RGB1W_SHORT_1		;SHORT DATA IN SFR IF <=0X60
L=0092, P=0035, C=2F87 : 					CMPL  0X88-1
L=0093, P=0036, C=383B : 					JNC	  CMD_UNKNOWN       ;UNKNOWN COMMAND IF <=0X87
L=0094, P=0037, C=0000 : 					NOP
L=0095, P=0038, C=0000 : 					NOP
L=0096, P=0039, C=0000 : 					NOP
L=0097, P=003A, C=0000 : 					NOP
L=0098, P=003B, C=2801 : CMD_UNKNOWN:		MOVL  0X01				;ERROR CODE FOR UNKNOWN COMMAND
L=0099, P=003C, C=609A : 					JMP   CMD_RETURN
L=0100, ......, D=0000 : ;
L=0101, P=003D, C=0000 : DS1W_CONVERT:		NOP
L=0102, P=003E, C=728E : 					CALL  START_TEMPERAT
L=0103, P=003F, C=609A : 					JMP   CMD_RETURN
L=0104, ......, D=0000 : ;
L=0105, P=0040, C=0000 : DS1W_CONV_GET:		NOP
L=0106, P=0041, C=728E : 					CALL  START_TEMPERAT
L=0107, P=0042, C=309A : 					JNZ   CMD_RETURN		;FAILED
L=0108, P=0043, C=244B : 					MOVIA 75				;750mS
L=0109, P=0044, C=2228 : DS1W_WAIT_10MS:		MOVIP 40				;40*250=10mS
L=0110, P=0045, C=7248 : DS1W_WAIT_250US:	CALL  DELAY_250US		;250uS
L=0111, P=0046, C=1504 : 					DEC   SFR_INDIR_ADDR
L=0112, P=0047, C=3045 : 					JNZ   DS1W_WAIT_250US
L=0113, P=0048, C=1509 : 					DEC   SFR_INDIR_ADDR2
L=0114, P=0049, C=3044 : 					JNZ   DS1W_WAIT_10MS
L=0115, ......, D=0000 : ;					JMP   DS1W_GET_DATA
L=0116, ......, D=0000 : ;
L=0117, P=004A, C=0000 : DS1W_GET_DATA:		NOP
L=0118, P=004B, C=729A : 					CALL  READ_TEMPERAT
L=0119, P=004C, C=609A : 					JMP   CMD_RETURN
L=0120, ......, D=0000 : ;
L=0121, ......, D=0000 : ; RGB WITH SHORT DATA IN SFR, SOFTWARE ENCODE
L=0122, P=004D, C=0000 : RGB1W_SHORT:		NOP
