L=0037, P=0010, C=0000 : 					NOP
L=0038, ......, D=0000 : ;RGB1W_DLY_HALF_B0 93-4 CYCLES @160M
L=0039, P=0011, ...... : RGB1W_DLY_HALF_B0:
