L=0124, P=004F, C=400B : 					BC    SFR_PORT_IO,SB_PORT_OUT0	;DEFAULT OUTPUT LOW
L=0125, P=0050, C=480A : 					BS    SFR_PORT_DIR,SB_PORT_DIR0
L=0126, P=0051, C=010C : 					CLR   SFR_BIT_CONFIG
L=0127, P=0052, C=2806 : 					MOVL  0X06				;ERROR CODE FOR PIN RX HIGH
L=0128, P=0053, C=540B : 					BTSC  SFR_PORT_IO,SB_PORT_IN0	;PIN LOW
L=0129, P=0054, C=609A : 					JMP   CMD_RETURN		;PIN HIGH
